{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "max_depth": 3,
            "style": "folder"
          },
          "foreground": "#ffffff",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "branch_icon": "",
            "display_stash_count": false,
            "display_status": true,
            "status_formats": {
              "added": "+",
              "deleted": "x",
              "modified": "~",
              "untracked": "?"
            }
          },
          "foreground": "#999999",
          "type": "git",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "threshold": 500
          },
          "foreground": "#666666",
          "type": "executiontime",
          "style": "plain"
        },
        {
          "properties": {
            "time_format": "15:04"
          },
          "foreground": "#666666",
          "type": "time",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
