{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/schemas/theme.schema.json",
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "#ffffff",
          "properties": {
            "style": "folder",
            "max_depth": 3
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#999999",
          "properties": {
            "display_status": true,
            "display_stash_count": false,
            "branch_icon": "",
            "status_formats": {
              "added": "+",
              "modified": "~",
              "deleted": "x",
              "untracked": "?"
            }
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#666666",
          "properties": {
            "threshold": 500
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "#666666",
          "properties": {
            "time_format": "15:04"
          }
        }
      ]
    }
  ]
}
